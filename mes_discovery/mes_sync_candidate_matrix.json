      "decision": "reference_and_reconcile_only_initially",
      "fields": [
        {"plm": "equipment_name", "mes": "equipmentName", "required": true},
        {"plm": "equipment_recipe_name", "mes": "equipmentRecipeName", "required": true},
        {"plm": "recipe_name", "mes": "recipeName", "required": true},
        {"plm": "equipment_recipe_mode", "mes": "equipmentRecipeMode", "required": true}
