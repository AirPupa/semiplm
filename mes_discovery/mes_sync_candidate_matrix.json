{
  "captured_at": "2026-07-02",
  "purpose": "Candidate PLM-to-MES synchronization scope derived from MES modeling discovery.",
  "security_note": "This file stores design mapping only. It stores no MES credential.",
  "syncPolicy": {
    "sourceOfTruth": "PLM owns design, approval, version, release package, and audit. MES owns execution and runtime state.",
    "writePolicy": "No production MES write until sandbox, idempotency, approval gate, and rollback are implemented.",
    "idempotencyKey": ["objectType", "objectName", "objectVersion", "ecnNo"],
    "minimumReleaseState": ["approved", "released", "frozen"]
  },
  "candidates": [
    {
      "priority": 1,
      "plmDomain": "Product",
      "plmObject": "Product / ProductVersion",
      "mesObject": "ProductDef.basicInfo",
      "direction": "PLM_TO_MES",
      "decision": "sync",
      "fields": [
        {"plm": "model", "mes": "productDefName", "required": true},
        {"plm": "version", "mes": "productDefVersion", "required": true},
        {"plm": "name", "mes": "description", "required": false},
        {"plm": "product_type", "mes": "productType", "required": true},
        {"plm": "lifecycle or production_type", "mes": "productionType", "required": true},
        {"plm": "product_group", "mes": "productGroupName", "required": true},
        {"plm": "owner", "mes": "owner", "required": false},
        {"plm": "gross_die", "mes": "grossDie", "required": false}
      ],
      "notes": "ProductDef is the first write candidate because it defines the product/version identity used by downstream MES modeling."
    },
    {
      "priority": 1,
      "plmDomain": "Process",
      "plmObject": "ProcessRoute / ProcessStep",
