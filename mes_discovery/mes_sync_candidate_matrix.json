        {"plm": "route.version", "mes": "processFlowVersion", "required": true},
        {"plm": "steps.sequence", "mes": "sequence/order", "required": true},
        {"plm": "steps.operation", "mes": "processStepName or operation", "required": true},
        {"plm": "steps.key_params", "mes": "Content/Parameter", "required": false}
      ],
      "notes": "Needs MES field-level payload discovery before write because detail modules use items plus idsForDeleted/idsInUpdate/idsInAdd."
    },
    {
      "priority": 1,
      "plmDomain": "BOM",
      "plmObject": "BomHeader / BomItem",
      "mesObject": "ProductDef.bomName / bomVersion and BOM",
