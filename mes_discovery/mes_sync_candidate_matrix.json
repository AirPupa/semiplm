      "fields": [
        {"plm": "bom_type + product.model", "mes": "bomName", "required": true},
        {"plm": "version", "mes": "bomVersion", "required": false},
        {"plm": "items.material_code", "mes": "BOM item material", "required": true},
        {"plm": "items.quantity", "mes": "BOM item quantity", "required": true},
        {"plm": "items.process_step", "mes": "step binding", "required": false}
